{
  "name": "sales-companion-realtime-cdc",
  "target": "sales",
  "catalog": "sales",
  "schema": "realtime",
  "development": false,
  "continuous": true,
  "channel": "CURRENT",
  "edition": "ADVANCED",
  "photon": true,
  "clusters": [
    {
      "label": "default",
      "num_workers": 2,
      "node_type_id": "i3.xlarge",
      "autoscale": {
        "min_workers": 1,
        "max_workers": 4,
        "mode": "ENHANCED"
      },
      "spark_env_vars": {
        "MSK_BOOTSTRAP_SERVERS": "{{secrets/sales-companion/msk-bootstrap-servers}}"
      },
      "aws_attributes": {
        "instance_profile_arn": "{{secrets/sales-companion/databricks-instance-profile}}"
      }
    }
  ],
  "libraries": [
    {
      "notebook": {
        "path": "/Repos/sales-companion/ingestion/kafka/dlt_pipeline"
      }
    }
  ],
  "configuration": {
    "pipelines.trigger.interval": "10 seconds",
    "spark.databricks.delta.preview.enabled": "true"
  },
  "notifications": [
    {
      "email_recipients": ["naga.bathula@gmail.com"],
      "alerts": [
        "on-update-failure",
        "on-flow-failure"
      ]
    }
  ],
  "tags": {
    "team": "data-ai",
    "project": "sales-companion",
    "sprint": "2"
  }
}
