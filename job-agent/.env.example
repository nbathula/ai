# Copy to .env and fill in your values

# SerpAPI — get key at https://serpapi.com (100 free searches/month, paid plans from $50/month)
SERPAPI_KEY=your-serpapi-key

# OpenRouter — get key at https://openrouter.ai/keys
# Gives access to Claude Opus and 100+ other models through one API
OPENROUTER_API_KEY=sk-or-your-key-here

# Gmail — the account n8n sends FROM (use an App Password, not your main password)
# Generate at: Google Account → Security → 2-Step Verification → App Passwords
GMAIL_USER=your.email@gmail.com

# Where to send the daily digest (can be the same as GMAIL_USER)
NOTIFY_EMAIL=your.email@gmail.com
